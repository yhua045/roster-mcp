# Roster MCP Configuration
# Copy this file to .env and update with your values

# API Configuration
ROSTER_API_BASE_URL=http://localhost:8000
ROSTER_API_KEY=your_api_key_here

# Scheduler Configuration
SCHEDULE_INTERVAL_HOURS=24
SCHEDULE_ENABLED=true

# AI Configuration (choose your provider)
AI_MODEL=gpt-3.5-turbo
AI_API_KEY=your_ai_api_key_here

# Database Configuration (optional)
# DATABASE_URL=sqlite:///roster.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/roster.log

# Feature Flags
DRY_RUN=false
AUTO_APPROVE=false

# Roster Output Configuration
WRITE_ROSTER_JSON=true
ROSTER_OUTPUT_DIR=roster-json

# AI Agent Configuration
HISTORICAL_MONTHS=3
FUTURE_MONTHS=3

# Roster Generation Rules
MAX_ASSIGNMENTS_PER_MONTH=4
MIN_REST_DAYS=7
PREFER_ROLE_ROTATION=true